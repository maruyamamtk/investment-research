# ==========================================
# 投資調査自動化システム 設定ファイル（サンプル）
# ==========================================
# 【ローカル開発】このファイルをコピーして config/settings.yaml を作成し、
# 各 APIキー・パスワードを直接設定してください（gitignore 対象）。
#   cp config/settings.yaml.example config/settings.yaml
#
# 【本番環境 (Cloud Run)】認証情報は GCP Secret Manager + 環境変数で注入されます。
# settings.yaml の値は空白のまま、以下の環境変数が優先されます。
#   JQUANTS_API_KEY            → api.jquants.api_key  ← V2はこれを使用
#   JQUANTS_EMAIL              → api.jquants.email     （V1廃止のため未使用）
#   JQUANTS_PASSWORD           → api.jquants.password  （V1廃止のため未使用）
#   GEMINI_API_KEY             → api.gemini.api_key
#   LINE_CHANNEL_ACCESS_TOKEN  → api.line.channel_access_token
#   LINE_USER_ID               → api.line.user_id
#
# Secret Manager への登録コマンド例:
#   echo -n "value" | gcloud secrets create jquants-email --data-file=- --project PROJECT_ID
# ==========================================

# --- API認証情報 ---
api:
  jquants:
    api_key: "your-jquants-api-key"        # V2 APIキー（必須）。または環境変数 JQUANTS_API_KEY
    email: "your-email@example.com"        # V1廃止のため未使用（後方互換のため残置）
    password: "your-jquants-password"      # V1廃止のため未使用（後方互換のため残置）
  gemini:
    api_key: "your-gemini-api-key"         # または環境変数 GEMINI_API_KEY
    model_weekly: "gemini-2.5-flash"
    model_daily:  "gemini-2.5-flash"
  line:
    channel_access_token: "your-line-channel-access-token"  # または環境変数 LINE_CHANNEL_ACCESS_TOKEN
    user_id: "your-line-user-id"                            # または環境変数 LINE_USER_ID
    enabled: true
    notify_time: "09:00"

# --- スクリーニング閾値 ---
screener:
  step1:
    min_market_cap_jpy: 10_000_000_000
    min_revenue_growth: -0.10
    min_operating_margin: 0.0
    min_pbr: 0.0
    min_equity_ratio: 0.10

  step2:
    min_eps_annual_growth: 0.25
    min_eps_quarterly_growth: 0.25
    min_revenue_growth_latest: 0.25
    min_roe: 0.15
    min_revenue_cagr_3yr: 0.05
    min_fcf_positive_years: 2
    min_cf_quality: 0.80
    max_net_debt_ebitda: 3.0
    max_payout_ratio: 0.70
    top_n_candidates: 20
    ai_analysis_top_n: 20               # AI定性分析の対象銘柄数（投資メモ・ベアケース・Q1〜Q5）

  weights:
    roe: 0.25
    revenue_cagr: 0.20
    fcf_quality: 0.20
    net_debt_ebitda: 0.15
    operating_margin: 0.10
    payout_ratio: 0.10

# --- テクニカル分析パラメータ ---
technical:
  sma_periods: [5, 20, 75]
  ema_periods: [12, 26]
  macd:
    fast: 12
    slow: 26
    signal: 9
  rsi_period: 14
  bollinger:
    period: 20
    std_dev: 2.0
  volume_ratio_threshold: 1.2
  signal_thresholds:
    rsi_oversold: 35
    rsi_overbought: 75
    earnings_hold_days: 3
    stop_loss_pct: 0.10

  # シグナルスコアの重み上書き（省略時は src/technical/signals.py の DEFAULT_WEIGHTS）
  # signal_weights:
  #   gc_new: 3          # ゴールデンクロス発生
  #   gc_hold: 1         # ゴールデンクロス維持
  #   dc_new: 3          # デッドクロス発生（SELL側）
  #   dc_hold: 1         # デッドクロス維持（SELL側）
  #   rsi_reversal: 0    # RSI反転（逆張り成分: 方向逆転が判明し無効化済み）
  #   rsi_zone: 0        # RSIゾーン滞留（同上）
  #   macd_cross: 2      # MACD転換
  #   macd_zone: 1       # MACD圏内滞留
  #   bb_break: 0        # ボリンジャーバンドブレイク（逆張り成分: 無効化済み）
  #   volume_confirm: 1  # 出来高確度加点
  #   pattern_scale: 1.0 # チャートパターン倍率
  #   sell_threshold: 4  # SELL閾値（バックテストにより3→4に変更済み）

# --- データ取得設定 ---
data:
  history_days: 400
  batch_size: 30
  batch_sleep_sec: 2.0
  cache_ttl_hours:
    stock_list: 168
    fundamentals: 168
    price_history: 24

# --- 出力設定 ---
output:
  weekly_report: "output/weekly_moat_stocks.md"
  daily_signals_md: "output/daily_trade_signals.md"
  daily_signals_csv: "output/signals.csv"
  watchlist_cache: "cache/watchlist.json"
  step1_cache: "cache/step1_results.json"
  step2_cache: "cache/step2_results.json"
  portfolio_report: "output/portfolio_report.md"

# --- ログ設定 ---
logging:
  level: "INFO"
  dir: "logs"
